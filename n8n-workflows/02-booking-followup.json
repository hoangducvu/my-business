{
  "name": "Oddly Craft — 02 Booking Follow-up Sequence",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "oddlycraft-booking-followup",
        "responseMode": "onReceived",
        "responseData": "allEntries",
        "options": {}
      },
      "id": "b2c3d4e5-0002-4000-8000-000000000001",
      "name": "Receive Booking",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300],
      "webhookId": "oddlycraft-booking-followup"
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\n\n// Parse booking date + time into a full ISO datetime\n// Assumes date is 'YYYY-MM-DD' and time is 'HH:MM' (24h) or '10:00 AM' etc.\nconst dateStr = item.date || '';\nconst timeStr = item.time || '10:00';\n\n// Normalize time to 24h if needed\nlet time24 = timeStr;\nconst ampmMatch = timeStr.match(/(\\d+):(\\d+)\\s*(AM|PM)/i);\nif (ampmMatch) {\n  let h = parseInt(ampmMatch[1]);\n  const m = ampmMatch[2];\n  const period = ampmMatch[3].toUpperCase();\n  if (period === 'PM' && h !== 12) h += 12;\n  if (period === 'AM' && h === 12) h = 0;\n  time24 = `${String(h).padStart(2, '0')}:${m}`;\n}\n\nconst bookingMs = new Date(`${dateStr}T${time24}:00`).getTime();\n\n// Calculate trigger times\nconst dayBeforeEvening = new Date(bookingMs - 16 * 60 * 60 * 1000); // 16h before session\nconst morningOfBooking = new Date(`${dateStr}T08:00:00`);\nconst dayAfter10am = new Date(bookingMs + 24 * 60 * 60 * 1000);\ndayAfter10am.setHours(10, 0, 0, 0);\nconst twoWeeksLater = new Date(bookingMs + 14 * 24 * 60 * 60 * 1000);\ntwoWeeksLater.setHours(10, 0, 0, 0);\n\nreturn [{\n  json: {\n    ...item,\n    bookingISO: new Date(`${dateStr}T${time24}:00`).toISOString(),\n    dayBeforeEvening: dayBeforeEvening.toISOString(),\n    morningOfBooking: morningOfBooking.toISOString(),\n    dayAfter10am: dayAfter10am.toISOString(),\n    twoWeeksLater: twoWeeksLater.toISOString(),\n    activityLabel: item.activity || 'craft session',\n    partySizeLabel: item.partySize === 1 ? '1 person' : `${item.partySize} people`\n  }\n}];"
      },
      "id": "b2c3d4e5-0002-4000-8000-000000000002",
      "name": "Calculate Trigger Dates",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "fromEmail": "hello@oddlycraft.com",
        "toEmail": "={{ $json.email }}",
        "subject": "=Your Oddly Craft session is confirmed! 🎉 — {{ $json.date }}",
        "emailType": "html",
        "message": "=<!DOCTYPE html>\n<html>\n<body style=\"margin:0;padding:0;background:#f9f6f1;font-family:'Helvetica Neue',Arial,sans-serif;\">\n<div style=\"max-width:580px;margin:40px auto;background:#ffffff;border-radius:16px;overflow:hidden;box-shadow:0 4px 24px rgba(0,0,0,0.08);\">\n  <div style=\"background:#2249a8;padding:36px 40px;text-align:center;\">\n    <p style=\"color:#ffd234;font-size:13px;letter-spacing:2px;text-transform:uppercase;margin:0 0 8px;\">Booking Confirmed</p>\n    <h1 style=\"color:#ffffff;margin:0;font-size:28px;font-weight:700;\">You're all set, {{ $json.firstName }}!</h1>\n  </div>\n  <div style=\"padding:36px 40px;\">\n    <p style=\"color:#444;font-size:16px;line-height:1.6;\">We're so excited to have you join us at Oddly Craft Malta. Here are your booking details:</p>\n    <div style=\"background:#f0f4ff;border-radius:12px;padding:24px;margin:24px 0;\">\n      <table style=\"width:100%;border-collapse:collapse;\">\n        <tr><td style=\"padding:8px 0;color:#7878a0;font-size:13px;text-transform:uppercase;letter-spacing:1px;\">Activity</td><td style=\"padding:8px 0;color:#2249a8;font-weight:700;font-size:15px;\">{{ $json.activityLabel }}</td></tr>\n        <tr><td style=\"padding:8px 0;color:#7878a0;font-size:13px;text-transform:uppercase;letter-spacing:1px;\">Date</td><td style=\"padding:8px 0;color:#1a1a2e;font-weight:600;font-size:15px;\">{{ $json.date }}</td></tr>\n        <tr><td style=\"padding:8px 0;color:#7878a0;font-size:13px;text-transform:uppercase;letter-spacing:1px;\">Time</td><td style=\"padding:8px 0;color:#1a1a2e;font-weight:600;font-size:15px;\">{{ $json.time }}</td></tr>\n        <tr><td style=\"padding:8px 0;color:#7878a0;font-size:13px;text-transform:uppercase;letter-spacing:1px;\">Party size</td><td style=\"padding:8px 0;color:#1a1a2e;font-weight:600;font-size:15px;\">{{ $json.partySizeLabel }}</td></tr>\n        <tr><td style=\"padding:8px 0;color:#7878a0;font-size:13px;text-transform:uppercase;letter-spacing:1px;\">Location</td><td style=\"padding:8px 0;color:#1a1a2e;font-weight:600;font-size:15px;\">Mercury Tower, St. Julian's, Malta</td></tr>\n      </table>\n    </div>\n    <p style=\"color:#444;font-size:15px;line-height:1.7;\"><strong>What to bring:</strong> Just yourself and your creativity! We provide all materials — charms, cases, tools, and plenty of good vibes.</p>\n    <p style=\"color:#444;font-size:15px;line-height:1.7;\">If you need to reschedule or have any questions, reply to this email and we'll sort it out.</p>\n    <div style=\"text-align:center;margin:32px 0;\">\n      <a href=\"https://www.instagram.com/oddlycraft.malta\" style=\"display:inline-block;background:#2249a8;color:#ffffff;text-decoration:none;padding:14px 32px;border-radius:8px;font-weight:700;font-size:15px;\">See our latest creations on Instagram</a>\n    </div>\n    <p style=\"color:#888;font-size:13px;text-align:center;\">See you soon — Team Oddly Craft 🎨</p>\n  </div>\n  <div style=\"background:#f0f4ff;padding:20px 40px;text-align:center;\">\n    <p style=\"color:#aaa;font-size:12px;margin:0;\">Oddly Craft Malta · Mercury Tower, St. Julian's · <a href=\"https://oddlycraft.com\" style=\"color:#2249a8;\">oddlycraft.com</a></p>\n  </div>\n</div>\n</body>\n</html>",
        "options": {}
      },
      "id": "b2c3d4e5-0002-4000-8000-000000000003",
      "name": "Email 1 — Booking Confirmation",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2.1,
      "position": [680, 300],
      "notes": "SETUP: Add SMTP credential. Use Brevo (brevo.com) free tier: 300 emails/day. SMTP host: smtp-relay.brevo.com, port 587, TLS."
    },
    {
      "parameters": {
        "resume": "specificTime",
        "date": "={{ $json.dayBeforeEvening }}"
      },
