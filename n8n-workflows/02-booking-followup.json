    {
      "parameters": {
        "fromEmail": "hello@oddlycraft.com",
        "toEmail": "={{ $json.email }}",
        "subject": "=How was your Oddly Craft experience? ⭐",
        "emailType": "html",
        "message": "=<!DOCTYPE html>\n<html>\n<body style=\"margin:0;padding:0;background:#f9f6f1;font-family:'Helvetica Neue',Arial,sans-serif;\">\n<div style=\"max-width:580px;margin:40px auto;background:#ffffff;border-radius:16px;overflow:hidden;box-shadow:0 4px 24px rgba(0,0,0,0.08);\">\n  <div style=\"background:#ffd234;padding:36px 40px;text-align:center;\">\n    <p style=\"color:#2249a8;font-size:13px;letter-spacing:2px;text-transform:uppercase;margin:0 0 8px;\">Thank You</p>\n    <h1 style=\"color:#1a1a2e;margin:0;font-size:26px;font-weight:700;\">Hope you had an amazing time, {{ $json.firstName }}!</h1>\n  </div>\n  <div style=\"padding:36px 40px;\">\n    <p style=\"color:#444;font-size:16px;line-height:1.6;\">Yesterday you joined us for a <strong>{{ $json.activityLabel }}</strong> session and we hope you walked away with something you're proud of — and maybe a little addicted to crafting! 😄</p>\n    <p style=\"color:#444;font-size:15px;line-height:1.7;\">Your review means the world to a small business like ours. If you enjoyed your experience, please take 60 seconds to leave us a Google review:</p>\n    <div style=\"text-align:center;margin:28px 0;\">\n      <a href=\"https://g.page/r/YOUR_GOOGLE_REVIEW_LINK\" style=\"display:inline-block;background:#2249a8;color:#ffffff;text-decoration:none;padding:14px 32px;border-radius:8px;font-weight:700;font-size:15px;\">⭐ Leave a Google Review</a>\n    </div>\n    <p style=\"color:#444;font-size:15px;line-height:1.7;\">If anything wasn't perfect, please just reply to this email and tell us — we read every message and take it seriously.</p>\n    <p style=\"color:#444;font-size:15px;line-height:1.7;\">Tag us on Instagram <strong>@oddlycraft.malta</strong> if you share your creation — we love to see and repost your work!</p>\n    <p style=\"color:#888;font-size:13px;text-align:center;margin-top:32px;\">Thank you for choosing Oddly Craft Malta 💙</p>\n  </div>\n</div>\n</body>\n</html>",
        "options": {}
      },
      "id": "b2c3d4e5-0002-4000-8000-000000000009",
      "name": "Email 4 — Thank You + Review Request",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2.1,
      "position": [2000, 300],
      "notes": "SETUP: Replace YOUR_GOOGLE_REVIEW_LINK with your actual Google Business review URL"
    },
    {
      "parameters": {
        "resume": "specificTime",
        "date": "={{ $json.twoWeeksLater }}"
      },
