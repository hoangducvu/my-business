    {
      "parameters": {
        "fromEmail": "hello@oddlycraft.com",
        "toEmail": "={{ $json.email }}",
        "subject": "=See you tomorrow at Oddly Craft! 📍",
        "emailType": "html",
        "message": "=<!DOCTYPE html>\n<html>\n<body style=\"margin:0;padding:0;background:#f9f6f1;font-family:'Helvetica Neue',Arial,sans-serif;\">\n<div style=\"max-width:580px;margin:40px auto;background:#ffffff;border-radius:16px;overflow:hidden;box-shadow:0 4px 24px rgba(0,0,0,0.08);\">\n  <div style=\"background:#1a3a8c;padding:36px 40px;text-align:center;\">\n    <p style=\"color:#ffd234;font-size:13px;letter-spacing:2px;text-transform:uppercase;margin:0 0 8px;\">Tomorrow</p>\n    <h1 style=\"color:#ffffff;margin:0;font-size:26px;font-weight:700;\">Almost time to get crafty, {{ $json.firstName }}!</h1>\n  </div>\n  <div style=\"padding:36px 40px;\">\n    <p style=\"color:#444;font-size:16px;line-height:1.6;\">Just a quick reminder — your <strong>{{ $json.activityLabel }}</strong> session is tomorrow at <strong>{{ $json.time }}</strong>.</p>\n    <div style=\"background:#f0f4ff;border-left:4px solid #2249a8;border-radius:0 8px 8px 0;padding:16px 20px;margin:24px 0;\">\n      <p style=\"margin:0;color:#2249a8;font-weight:700;font-size:15px;\">📍 Mercury Tower, St. Julian's, Malta</p>\n      <p style=\"margin:8px 0 0;color:#555;font-size:14px;\">Parking available nearby. Look for the Oddly Craft sign!</p>\n    </div>\n    <p style=\"color:#444;font-size:15px;line-height:1.7;\">✅ Everything is prepared for {{ $json.partySizeLabel }}<br>✅ All materials and tools included<br>✅ No experience needed — just show up!</p>\n    <p style=\"color:#444;font-size:15px;line-height:1.7;\">Questions? Just reply to this email.</p>\n    <p style=\"color:#888;font-size:13px;text-align:center;margin-top:32px;\">Can't wait to see what you create! — Team Oddly Craft 🎨</p>\n  </div>\n</div>\n</body>\n</html>",
        "options": {}
      },
      "id": "b2c3d4e5-0002-4000-8000-000000000005",
      "name": "Email 2 — Day Before Reminder",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2.1,
      "position": [1120, 300]
    },
