    {
      "parameters": {
        "fromEmail": "hello@oddlycraft.com",
        "toEmail": "={{ $json.email }}",
        "subject": "=Come back to Oddly Craft — bring a friend! 🎁",
        "emailType": "html",
        "message": "=<!DOCTYPE html>\n<html>\n<body style=\"margin:0;padding:0;background:#f9f6f1;font-family:'Helvetica Neue',Arial,sans-serif;\">\n<div style=\"max-width:580px;margin:40px auto;background:#ffffff;border-radius:16px;overflow:hidden;box-shadow:0 4px 24px rgba(0,0,0,0.08);\">\n  <div style=\"background:#2249a8;padding:36px 40px;text-align:center;\">\n    <p style=\"color:#ffd234;font-size:13px;letter-spacing:2px;text-transform:uppercase;margin:0 0 8px;\">We Miss You</p>\n    <h1 style=\"color:#ffffff;margin:0;font-size:26px;font-weight:700;\">It's been two weeks, {{ $json.firstName }} 👋</h1>\n  </div>\n  <div style=\"padding:36px 40px;\">\n    <p style=\"color:#444;font-size:16px;line-height:1.6;\">We've been busy creating new Italian charm designs and fresh phone case styles since your visit. There's always something new to discover at Oddly Craft!</p>\n    <p style=\"color:#444;font-size:15px;line-height:1.7;\">Why not make it a date? Bring a friend, a colleague, or your family for a fun creative session together. Groups love it here.</p>\n    <div style=\"text-align:center;margin:28px 0;\">\n      <a href=\"https://oddlycraft.com\" style=\"display:inline-block;background:#2249a8;color:#ffffff;text-decoration:none;padding:14px 32px;border-radius:8px;font-weight:700;font-size:15px;\">Book Your Next Session</a>\n    </div>\n    <p style=\"color:#444;font-size:15px;line-height:1.7;\">Or follow us on <a href=\"https://www.instagram.com/oddlycraft.malta\" style=\"color:#2249a8;\">@oddlycraft.malta</a> to stay inspired!</p>\n    <p style=\"color:#888;font-size:13px;text-align:center;margin-top:32px;\">Hope to see you again soon — Team Oddly Craft 🎨</p>\n  </div>\n</div>\n</body>\n</html>",
        "options": {}
      },
