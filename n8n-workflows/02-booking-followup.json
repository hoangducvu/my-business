    {
      "parameters": {
        "fromEmail": "hello@oddlycraft.com",
        "toEmail": "={{ $json.email }}",
        "subject": "=Today's the day! We're ready for you 🎨",
        "emailType": "html",
        "message": "=<!DOCTYPE html>\n<html>\n<body style=\"margin:0;padding:0;background:#f9f6f1;font-family:'Helvetica Neue',Arial,sans-serif;\">\n<div style=\"max-width:580px;margin:40px auto;background:#ffffff;border-radius:16px;overflow:hidden;box-shadow:0 4px 24px rgba(0,0,0,0.08);\">\n  <div style=\"background:#2249a8;padding:36px 40px;text-align:center;\">\n    <p style=\"color:#ffd234;font-size:36px;margin:0 0 8px;\">🎉</p>\n    <h1 style=\"color:#ffffff;margin:0;font-size:26px;font-weight:700;\">It's craft day, {{ $json.firstName }}!</h1>\n  </div>\n  <div style=\"padding:36px 40px;text-align:center;\">\n    <p style=\"color:#444;font-size:16px;line-height:1.6;\">Your <strong>{{ $json.activityLabel }}</strong> session is today at <strong>{{ $json.time }}</strong>. We're all set up and can't wait to see you.</p>\n    <div style=\"background:#2249a8;border-radius:12px;padding:20px;margin:24px 0;\">\n      <p style=\"color:#ffd234;font-weight:700;font-size:16px;margin:0;\">📍 Mercury Tower, St. Julian's, Malta</p>\n    </div>\n    <p style=\"color:#555;font-size:14px;\">See you soon! — Team Oddly Craft</p>\n  </div>\n</div>\n</body>\n</html>",
        "options": {}
      },
