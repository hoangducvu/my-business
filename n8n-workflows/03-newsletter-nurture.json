    {
      "parameters": {
        "fromEmail": "hello@oddlycraft.com",
        "toEmail": "={{ $json.email }}",
        "subject": "=Perfect for groups — here's why teams love Oddly Craft 🤝",
        "emailType": "html",
        "message": "=<!DOCTYPE html>\n<html>\n<body style=\"margin:0;padding:0;background:#f9f6f1;font-family:'Helvetica Neue',Arial,sans-serif;\">\n<div style=\"max-width:580px;margin:40px auto;background:#ffffff;border-radius:16px;overflow:hidden;\">\n  <div style=\"background:#ffd234;padding:36px 40px;\">\n    <p style=\"color:#2249a8;font-size:13px;letter-spacing:2px;text-transform:uppercase;margin:0 0 8px;\">Groups & Events</p>\n    <h1 style=\"color:#1a1a2e;margin:0;font-size:24px;font-weight:700;\">Looking for something different for your next group outing?</h1>\n  </div>\n  <div style=\"padding:36px 40px;\">\n    <p style=\"color:#444;font-size:16px;line-height:1.6;\">Oddly Craft is perfect for groups of all kinds. Here's what we hear most:</p>\n    <ul style=\"color:#444;font-size:15px;line-height:1.9;\">\n      <li><strong>Birthday parties</strong> — a creative twist on the usual dinner out</li>\n      <li><strong>Hen do / bachelorette</strong> — make matching bracelets as a keepsake</li>\n      <li><strong>Team building</strong> — companies love the relaxed, creative atmosphere</li>\n      <li><strong>Date nights</strong> — crafting together is surprisingly romantic!</li>\n      <li><strong>Family visits</strong> — great for kids aged 8+ and adults alike</li>\n    </ul>\n    <p style=\"color:#444;font-size:15px;line-height:1.7;\">We can accommodate groups of up to 20 people. For larger groups, contact us directly.</p>\n    <div style=\"text-align:center;margin:28px 0;\">\n      <a href=\"https://oddlycraft.com\" style=\"display:inline-block;background:#2249a8;color:#ffffff;text-decoration:none;padding:14px 32px;border-radius:8px;font-weight:700;font-size:15px;\">Book for a Group</a>\n    </div>\n  </div>\n</div>\n</body>\n</html>",
        "options": {}
      },
      "id": "c3d4e5f6-0003-4000-8000-000000000008",
      "name": "Email 4 — Groups & Events",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2.1,
      "position": [1780, 300]
    },
    {
      "parameters": { "amount": 2, "unit": "days" },
      "id": "c3d4e5f6-0003-4000-8000-000000000009",
