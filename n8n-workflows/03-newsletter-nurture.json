      "name": "Wait 3 Days",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1.1,
      "position": [2440, 300]
    },
    {
      "parameters": {
        "fromEmail": "hello@oddlycraft.com",
        "toEmail": "={{ $json.email }}",
        "subject": "=Spots fill up fast on weekends — here's why 👀",
        "emailType": "html",
        "message": "=<!DOCTYPE html>\n<html>\n<body style=\"margin:0;padding:0;background:#f9f6f1;font-family:'Helvetica Neue',Arial,sans-serif;\">\n<div style=\"max-width:580px;margin:40px auto;background:#ffffff;border-radius:16px;overflow:hidden;\">\n  <div style=\"background:#c9a84c;padding:36px 40px;\">\n    <p style=\"color:#fff;font-size:13px;letter-spacing:2px;text-transform:uppercase;margin:0 0 8px;\">Limited Availability</p>\n    <h1 style=\"color:#1a1a2e;margin:0;font-size:24px;font-weight:700;\">Weekend sessions at Oddly Craft book out fast.</h1>\n  </div>\n  <div style=\"padding:36px 40px;\">\n    <p style=\"color:#444;font-size:16px;line-height:1.6;\">Malta is a small island — and once word got out about Oddly Craft, weekends started filling up weeks in advance. If you've been thinking about booking, now is a good time.</p>\n    <p style=\"color:#444;font-size:15px;line-height:1.7;\">Weekday sessions have more availability and are great for a quieter, more personal experience. Either way — don't leave it too long.</p>\n    <div style=\"background:#fff8e1;border-left:4px solid #c9a84c;border-radius:0 8px 8px 0;padding:16px 20px;margin:24px 0;\">\n      <p style=\"margin:0;color:#8a6a00;font-weight:700;font-size:15px;\">✦ Italian Charm Bracelets — highly popular</p>\n      <p style=\"margin:6px 0 0;color:#8a6a00;font-weight:700;font-size:15px;\">✦ Custom Phone Cases — also in high demand</p>\n    </div>\n    <div style=\"text-align:center;margin:28px 0;\">\n      <a href=\"https://oddlycraft.com\" style=\"display:inline-block;background:#2249a8;color:#ffffff;text-decoration:none;padding:14px 32px;border-radius:8px;font-weight:700;font-size:15px;\">Check Availability Now</a>\n    </div>\n  </div>\n</div>\n</body>\n</html>",
        "options": {}
      },
      "id": "c3d4e5f6-0003-4000-8000-000000000012",
      "name": "Email 6 — Urgency",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2.1,
      "position": [2660, 300]
    },
    {
      "parameters": { "amount": 3, "unit": "days" },
      "id": "c3d4e5f6-0003-4000-8000-000000000013",
