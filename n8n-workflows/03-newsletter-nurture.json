    {
      "parameters": {
        "fromEmail": "hello@oddlycraft.com",
        "toEmail": "={{ $json.email }}",
        "subject": "=Welcome to Oddly Craft, {{ $json.firstName }}! 🌟",
        "emailType": "html",
        "message": "=<!DOCTYPE html>\n<html>\n<body style=\"margin:0;padding:0;background:#f9f6f1;font-family:'Helvetica Neue',Arial,sans-serif;\">\n<div style=\"max-width:580px;margin:40px auto;background:#ffffff;border-radius:16px;overflow:hidden;box-shadow:0 4px 24px rgba(0,0,0,0.08);\">\n  <div style=\"background:#2249a8;padding:36px 40px;text-align:center;\">\n    <p style=\"color:#ffd234;font-size:13px;letter-spacing:2px;text-transform:uppercase;margin:0 0 8px;\">Welcome!</p>\n    <h1 style=\"color:#ffffff;margin:0;font-size:28px;font-weight:700;\">Hi {{ $json.firstName }}, you're in! 🎉</h1>\n  </div>\n  <div style=\"padding:36px 40px;\">\n    <p style=\"color:#444;font-size:16px;line-height:1.6;\">Thanks for subscribing to Oddly Craft Malta. You've just joined a community of people who believe crafting should be fun, social, and accessible to everyone — no artistic talent required.</p>\n    <p style=\"color:#444;font-size:15px;line-height:1.7;\">Here's a quick taste of what we do:</p>\n    <div style=\"display:flex;gap:0;margin:20px 0;\">\n      <div style=\"flex:1;background:#f0f4ff;border-radius:10px;padding:18px;margin:0 6px 0 0;text-align:center;\">\n        <p style=\"font-size:28px;margin:0 0 8px;\">💎</p>\n        <p style=\"color:#2249a8;font-weight:700;font-size:14px;margin:0;\">Italian Charm Bracelets</p>\n        <p style=\"color:#888;font-size:12px;margin:6px 0 0;\">Design your own custom charm bracelet</p>\n      </div>\n      <div style=\"flex:1;background:#fff5ee;border-radius:10px;padding:18px;margin:0 0 0 6px;text-align:center;\">\n        <p style=\"font-size:28px;margin:0 0 8px;\">📱</p>\n        <p style=\"color:#e8a87c;font-weight:700;font-size:14px;margin:0;\">Custom Phone Cases</p>\n        <p style=\"color:#888;font-size:12px;margin:6px 0 0;\">One-of-a-kind designs, made by you</p>\n      </div>\n    </div>\n    <p style=\"color:#444;font-size:15px;line-height:1.7;\">We're based at <strong>Mercury Tower, St. Julian's, Malta</strong> and sessions are open to everyone — individuals, couples, friends, and corporate groups.</p>\n    <div style=\"text-align:center;margin:28px 0;\">\n      <a href=\"https://oddlycraft.com\" style=\"display:inline-block;background:#2249a8;color:#ffffff;text-decoration:none;padding:14px 32px;border-radius:8px;font-weight:700;font-size:15px;\">Explore Our Sessions</a>\n    </div>\n    <p style=\"color:#888;font-size:12px;text-align:center;\">Over the next two weeks, we'll share our best tips, inspiration, and a special offer. Stay tuned!</p>\n  </div>\n</div>\n</body>\n</html>",
        "options": {}
      },
      "id": "c3d4e5f6-0003-4000-8000-000000000002",
      "name": "Email 1 — Welcome",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2.1,
      "position": [460, 300],
      "notes": "SETUP: Add your SMTP credential (Brevo recommended — free 300 emails/day). Set fromEmail to your real sending address."
    },
